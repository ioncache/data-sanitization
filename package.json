{
  "name": "root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "bench": "yarn workspace data-sanitization bench",
    "build": "yarn workspaces foreach -A run build",
    "clean": "yarn workspaces foreach -A run clean",
    "format": "yarn workspaces foreach -A -v run format:src",
    "format:check": "yarn workspaces foreach -A -v run format:check:src",
    "format:check:src": "oxfmt --check . '!packages/**'",
    "format:src": "oxfmt . '!packages/**'",
    "lint": "yarn workspaces foreach -A -v run lint:code",
    "lint:actions": "github-actionlint",
    "lint:ci": "yarn workspaces foreach -A -v run lint:ci:code",
    "lint:ci:code": "oxlint -f github --ignore-pattern 'packages/**' && yarn lint:md && yarn lint:yaml",
    "lint:code": "oxlint -f default --ignore-pattern 'packages/**' && yarn lint:md && yarn lint:yaml",
    "lint:fix": "yarn workspaces foreach -A -v run lint:fix:code",
    "lint:fix:code": "oxlint --fix --ignore-pattern 'packages/**'",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!.yarn/**\" \"!node_modules/**\" \"!packages/**\" \"!CLAUDE.md\" \"!docs/plans/**\" \"!docs/superpowers/**\" \"!.ai/**\" \"!.remember/**\" \"!.agents/**\" \"!.claude/**\" \"!.github/instructions/**\" \"!.github/skills/**\" \"!.github/prompts/**\"",
    "lint:yaml": "yamllint \".github/**/*.yml\" \".github/**/*.yaml\" \".yarnrc.yml\"",
    "prepare": "husky || true",
    "release": "node scripts/release.mjs",
    "test": "yarn workspaces foreach -A run test",
    "test:coverage": "yarn workspaces foreach -A run test:coverage",
    "test:watch": "yarn workspace data-sanitization test:watch"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.0",
    "@inquirer/prompts": "^8.4.3",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.6",
    "github-actionlint": "^1.7.12",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "markdownlint-cli2": "^0.22.1",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "query-string": "^9.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "yaml-lint": "^1.7.0",
    "yargs": "^18.0.0"
  },
  "engines": {
    "node": ">=22.22.1"
  },
  "volta": {
    "node": "22.22.3",
    "yarn": "4.15.0"
  },
  "packageManager": "yarn@4.15.0"
}
