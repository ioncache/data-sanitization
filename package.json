{
  "name": "data-sanitization",
  "version": "1.0.1",
  "description": "Sanitization library for masking or removing sensitive data.",
  "keywords": [
    "sanitize",
    "sanitization",
    "data-sanitization",
    "redact",
    "redaction",
    "mask",
    "masking",
    "sensitive-data",
    "pii",
    "phi",
    "secrets",
    "logging",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ioncache/data-sanitization.git"
  },
  "homepage": "https://github.com/ioncache/data-sanitization#readme",
  "bugs": {
    "url": "https://github.com/ioncache/data-sanitization/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.22.1"
  },
  "author": "Mark Jubenville <ioncache@gmail.com>",
  "license": "MIT",
  "scripts": {
    "build": "yarn clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage *.tsbuildinfo",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepare": "husky",
    "prepack": "yarn build",
    "release": "node scripts/release.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.md": [
      "oxfmt"
    ],
    "*.{json,yml,yaml}": [
      "oxfmt"
    ],
    "*.sh": [
      "./scripts/shell_lint.sh"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.0",
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.6",
    "conventional-changelog": "^7.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "query-string": "^9.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "yargs": "^18.0.0"
  },
  "volta": {
    "node": "22.22.3",
    "yarn": "1.22.22"
  }
}
