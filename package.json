{
  "name": "data-sanitization",
  "version": "0.5.0",
  "description": "Sanitization library for obfuscating/removing/securing data.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "author": "Mark Jubenville <ioncache@gmail.com>",
  "license": "MIT",
  "scripts": {
    "build": "yarn clean && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "prepack": "yarn build",
    "release": "node scripts/release.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ],
    "*.sh": [
      "./scripts/shell_lint.sh"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.0",
    "conventional-changelog": "^7.1.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.3",
    "query-string": "^9.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^4.1.0",
    "yargs": "^18.0.0"
  },
  "volta": {
    "node": "20.19.0",
    "yarn": "1.22.19"
  }
}
