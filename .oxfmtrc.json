{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "printWidth": 80,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "useTabs": false,
  "sortPackageJson": false,
  "ignorePatterns": [
    "*.yaml",
    "*.yml",
    "package-lock.json",
    "yarn.lock",
    "dist",
    "node_modules"
  ]
}
